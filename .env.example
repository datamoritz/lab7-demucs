# Copy to .env before deploying — never commit .env to git.
#
#   cp .env.example .env
#   nano .env

# MinIO credentials
# MINIO_ACCESS_KEY must be at least 3 characters
# MINIO_SECRET_KEY must be at least 8 characters
MINIO_ACCESS_KEY=demucs
MINIO_SECRET_KEY=changeme-use-a-strong-password
MINIO_BUCKET=demucs-bucket
